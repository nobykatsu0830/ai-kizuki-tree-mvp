# コピーして .env を作る。値はTelegram/チャットに貼らない。
# cp .env.example .env

# LINE Developers > Messaging APIチャネル > チャネル基本設定
LINE_CHANNEL_SECRET=REPLACE_WITH_CHANNEL_SECRET

# LINE Developers > Messaging API設定 > チャネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=REPLACE_WITH_LONG_LIVED_ACCESS_TOKEN

# LINE Developers > チャネルID。現時点MVPでは未使用だが記録用。
LINE_CHANNEL_ID=REPLACE_WITH_CHANNEL_ID
